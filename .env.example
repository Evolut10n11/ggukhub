TELEGRAM_BOT_TOKEN=
BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./var/app.db
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
SPEECH_ENABLED=false
SPEECH_BASE_URL=
# Example: SPEECH_BASE_URL=local://faster-whisper
# Example: SPEECH_BASE_URL=https://api.openai.com/v1
SPEECH_API_KEY=
SPEECH_MODEL=small
SPEECH_LANGUAGE=ru
SPEECH_TIMEOUT_SECONDS=90

# Telegram
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_SECRET=

# Bitrix24 connection (set either webhook URL or REST URL + token)
BITRIX_WEBHOOK_URL=
BITRIX_REST_URL=
BITRIX_TOKEN=
BITRIX_SHARED_SECRET=

# Bitrix methods
BITRIX_TICKET_METHOD=crm.lead.add
BITRIX_COMMENT_METHOD=crm.timeline.comment.add
BITRIX_UPDATE_METHOD=crm.lead.update
BITRIX_ENTITY_TYPE=lead
BITRIX_ENTITY_TYPE_ID=1

# Bitrix field mapping
BITRIX_FIELD_TITLE=TITLE
BITRIX_FIELD_DESCRIPTION=COMMENTS
BITRIX_FIELD_PHONE=PHONE
BITRIX_FIELD_JK=UF_CRM_JK
BITRIX_FIELD_ADDRESS=UF_CRM_ADDRESS
BITRIX_FIELD_CATEGORY=UF_CRM_CATEGORY
BITRIX_FIELD_TELEGRAM_ID=UF_CRM_TELEGRAM_ID
BITRIX_FIELD_LOCAL_REPORT_ID=UF_CRM_LOCAL_REPORT_ID
BITRIX_FIELD_APARTMENT=UF_CRM_APARTMENT
BITRIX_FIELD_STATUS=STATUS_ID

# Incidents
INCIDENT_WINDOW_MINUTES=15
INCIDENT_THRESHOLD=5

SPEECH_DEVICE=cpu
SPEECH_COMPUTE_TYPE=int8
